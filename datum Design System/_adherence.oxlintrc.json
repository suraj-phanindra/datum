{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/drift/**",
              "components/tower/**",
              "ui_kits/tower/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Pixel|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Pixel, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:signal|variant|size|dot|live|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: signal, variant, size, dot, live, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='signal'] > Literal[value!=/^(?:neutral|amber|red|blue|green)$/]",
        "message": "<Badge> signal must be one of 'neutral' | 'amber' | 'red' | 'blue' | 'green'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BlastNode'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|label|status|key|ref|className|style|children)$/]",
        "message": "<BlastNode> doesn't accept that prop. Declared props: initials, label, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconOnly|leadingIcon|trailingIcon|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconOnly, leadingIcon, trailingIcon, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|eyebrow|actions|severity|inset|interactive|flush|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, eyebrow, actions, severity, inset, interactive, flush, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='severity'] > Literal[value!=/^(?:amber|red|blue|green)$/]",
        "message": "<Card> severity must be one of 'amber' | 'red' | 'blue' | 'green'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContractRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|version|live|drift|sessions|interactive|key|ref|className|style|children)$/]",
        "message": "<ContractRow> doesn't accept that prop. Declared props: name, version, live, drift, sessions, interactive."
      },
      {
        "selector": "JSXOpeningElement[name.name='DriftQuote'] > JSXAttribute > JSXIdentifier[name!=/^(?:who|text|key|ref|className|style|children)$/]",
        "message": "<DriftQuote> doesn't accept that prop. Declared props: who, text."
      },
      {
        "selector": "JSXOpeningElement[name.name='EpochNode'] > JSXAttribute > JSXIdentifier[name!=/^(?:v|time|state|key|ref|className|style|children)$/]",
        "message": "<EpochNode> doesn't accept that prop. Declared props: v, time, state."
      },
      {
        "selector": "JSXOpeningElement[name.name='EpochNode'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:past|current|live)$/]",
        "message": "<EpochNode> state must be one of 'past' | 'current' | 'live'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|prefix|suffix|mono|invalid|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, prefix, suffix, mono, invalid."
      },
      {
        "selector": "JSXOpeningElement[name.name='LedgerEntry'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|time|who|summary|head|interactive|key|ref|className|style|children)$/]",
        "message": "<LedgerEntry> doesn't accept that prop. Declared props: id, time, who, summary, head, interactive."
      },
      {
        "selector": "JSXOpeningElement[name.name='LifecycleChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:stage|elapsed|label|pending|done|key|ref|className|style|children)$/]",
        "message": "<LifecycleChip> doesn't accept that prop. Declared props: stage, elapsed, label, pending, done."
      },
      {
        "selector": "JSXOpeningElement[name.name='LiveDriftNode'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|who|label|key|ref|className|style|children)$/]",
        "message": "<LiveDriftNode> doesn't accept that prop. Declared props: initials, who, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='PresenceAvatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|name|size|active|ring|key|ref|className|style|children)$/]",
        "message": "<PresenceAvatar> doesn't accept that prop. Declared props: initials, name, size, active, ring."
      },
      {
        "selector": "JSXOpeningElement[name.name='PresenceAvatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<PresenceAvatar> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|version|live|size|as|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: icon, version, live, size, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Tag> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:span|button|a)$/]",
        "message": "<Tag> as must be one of 'span' | 'button' | 'a'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
